rule umap_dominant:
    input:
        contributions=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions.txt",
        umap=lambda wildcards:
            f"{config['cogapsOutDir']}/{wildcards.sample}/cogaps/patterns_{wildcards.npatterns}/umap/coo/{wildcards.sample}.npatterns-{wildcards.npatterns}.nmf.umap-coords.txt"
    output:
        pdf=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/{sample}.npatterns-{npatterns}.UMAP_dominant_{dataset}.pdf"
    params:
        dataset="{dataset}"
    wildcard_constraints:
        dataset="nmf"
    conda:
        "envs/cogaps.yml"
    script:
        "scripts/plot_umap_dominant.R"

