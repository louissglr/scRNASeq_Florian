rule render_report:
    input:
        qmd=reportqmd,
        contrib_cells=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
        contrib_genes=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_genes.txt",
        markers_excel=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/markers/{sample}.npatterns-{npatterns}.markers.xlsx",
        dotplot=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/markers/{sample}.npatterns-{npatterns}.dotplot.png",

        enrich_csv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/enrichment/{sample}.npatterns-{npatterns}.hallmarks_enrichment.csv",
        overr_csv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/overrep/{sample}.npatterns-{npatterns}.hallmarks_overrepresentation.csv",

        kw_csv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/statistics/{sample}.npatterns-{npatterns}.kw_results.csv",
        pairwise_csv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/statistics/{sample}.npatterns-{npatterns}.pairwise_results.csv",

        png_specificity_patterns=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/specificity/{sample}.npatterns-{npatterns}.plot_patterns.png",
        png_specificity_metagroups=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/specificity/{sample}.npatterns-{npatterns}.plot_metagroups.png",

        png_enrich_unique=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/enrichment/{sample}.npatterns-{npatterns}.hallmarks_enrichment_unique.png",
        png_overr_unique=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/overrep/{sample}.npatterns-{npatterns}.hallmarks_overrepresentation_unique.png",

        png_enrich_heatmap=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/enrichment/{sample}.npatterns-{npatterns}.hallmarks_enrichment_heatmap.png",
        png_overr_heatmap=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/get_function/overrep/{sample}.npatterns-{npatterns}.hallmarks_overrepresentation_heatmap.png",

        png_enrich_heatmap_manually=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/manually/enrichment/{sample}.npatterns-{npatterns}.hallmarks_enrichment_heatmap.png",
        png_overr_heatmap_manually=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/hallmarks/manually/overrep/{sample}.npatterns-{npatterns}.hallmarks_overrepresentation_heatmap.png",

        umap_nmf=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/{sample}.npatterns-{npatterns}.UMAP_dominant_nmf.png",

        umap_nb_cells=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/dominant/infos/{sample}.npatterns-{npatterns}.nb_cells.png",

        weight_nmf=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/weight/{sample}.npatterns-{npatterns}.UMAP_weight_nmf.png",

        benchmark_tsv="benchmarks/{sample}/{sample}-{npatterns}.tsv"

    output:
        html=report(
            config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/report/{sample}.npatterns-{npatterns}.report.html",
            category="{sample}",            # ← un onglet par sample
            subcategory="CoGAPS Report",
            labels={"patterns": "{npatterns}"}
        )

    params:
        outdir=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/report",
        sample="{sample}",
        npatterns="{npatterns}"

    log:
        "logs/{sample}/{sample}-{npatterns}.render_report.log"

    conda:
        "envs/quarto.yml"

    threads: 1

    shell:
        r"""
        mkdir -p "$(dirname "{log}")"
        LOGFILE=$(realpath "{log}")
        mkdir -p "{params.outdir}"

        export TMPDIR="${{TMPDIR:-/tmp}}"
        export DENO_DIR="$TMPDIR/quarto-deno-cache-{wildcards.sample}-{wildcards.npatterns}"
        export XDG_CACHE_HOME="$TMPDIR/quarto-xdg-cache-{wildcards.sample}-{wildcards.npatterns}"

        cp "{input.qmd}" "{params.outdir}/report_cogaps.qmd"
        cd "{params.outdir}"

        quarto render report_cogaps.qmd \
            --output "{params.sample}.npatterns-{params.npatterns}.report.html" \
            -P sample:"{params.sample}" \
            -P npatterns:"{params.npatterns}" \
            -P outdir:"{params.outdir}" \
            -P contrib_cells:"{input.contrib_cells}" \
            -P contrib_genes:"{input.contrib_genes}" \
            -P markers_excel:"{input.markers_excel}" \
            -P dotplot:"{input.dotplot}" \
            -P enrich_csv:"{input.enrich_csv}" \
            -P overr_csv:"{input.overr_csv}" \
            -P kw_csv:"{input.kw_csv}" \
            -P pairwise_csv:"{input.pairwise_csv}" \
            -P png_specificity_patterns:"{input.png_specificity_patterns}" \
            -P png_specificity_metagroups:"{input.png_specificity_metagroups}" \
            -P png_enrich_unique:"{input.png_enrich_unique}" \
            -P png_overr_unique:"{input.png_overr_unique}" \
            -P png_enrich_heatmap:"{input.png_enrich_heatmap}" \
            -P png_overr_heatmap:"{input.png_overr_heatmap}" \
            -P png_enrich_heatmap_manually:"{input.png_enrich_heatmap_manually}" \
            -P png_overr_heatmap_manually:"{input.png_overr_heatmap_manually}" \
            -P umap_nmf:"{input.umap_nmf}" \
            -P umap_nb_cells:"{input.umap_nb_cells}" \
            -P weight_nmf:"{input.weight_nmf}" \
            -P benchmark_tsv:"{input.benchmark_tsv}" \
            > "$LOGFILE" 2>&1
        """
 