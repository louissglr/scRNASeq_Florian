rule cogaps:
    input:
        tumor_rna_seuratobj = config["dataDir"] + "/{sample}.seurat-object.rds"
    output:
        cogaps_rds = config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/object/{sample}.npatterns-{npatterns}.cogaps-object.Rds"
    log:
        "logs/{sample}/{sample}-{npatterns}.log"
    benchmark:
        "benchmarks/{sample}/{sample}-{npatterns}.tsv"
    conda:
        "envs/cogaps.yml"
    threads: 80
    params:
        npatterns = "{npatterns}",
        nIterations = config["cogapsIterations"]
    script:
        "scripts/run_cogaps.R"


rule reduce_dim_cogaps:
    input:
        contrib_tsv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/contributions/{sample}.npatterns-{npatterns}.contributions_cells.txt",
    output:
        tsv=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/umap/coo/{sample}.npatterns-{npatterns}.nmf.umap-coords.txt",
    conda:
        "envs/cogaps.yml"
    threads: 1
    script:
        "scripts/reduce_dim.R"


rule pattern_markers:
    input:
        cogaps_rds = config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/object/{sample}.npatterns-{npatterns}.cogaps-object.Rds"
    output:
        excel=config["cogapsOutDir"] + "/{sample}/cogaps/patterns_{npatterns}/markers/{sample}.npatterns-{npatterns}.markers.xlsx"
    conda:
        "envs/cogaps.yml"
    threads: 1
    script:
        "scripts/run_pattern_markers.R"

